<?php

/** @var \Magento\Framework\View\Element\Template $block */
/** @var \MagStore\ProductFeatures\ViewModel\SliderProducts $viewModel */

$viewModel = $block->getData('view_model');
$products = $viewModel->getCarouselProducts();

if (empty($products)) return;

$sliderConfig = $block->getData('slider_config') ?: [
    'slidesToShow' => 2,
    'slidesToScroll' => 1,
    'dots' => true,
    'infinite' => true,
    'arrows' => false
];

$cssClass = $block->getData('css_class') ?: 'default-slider';

$uniqueId = 'slider_' . uniqid();
?>

<div class="carousel-container <?= $block->escapeHtmlAttr($cssClass) ?>">
    <div id="<?= $uniqueId ?>" class="carousel-test-list">
        <?php foreach ($products as $product): ?>
            <div class="item product-item">
                <a href="<?= $block->escapeUrl($product->getProductUrl()) ?>" class="product-link">
                    <img class="carousel-img"
                        src="<?= $block->escapeUrl($viewModel->getImageUrl($product)) ?>"
                        alt="<?= $block->escapeHtmlAttr($product->getName()) ?>" />

                    <div class="carousel-description">
                        <strong class="product-name"><?= $block->escapeHtml($product->getName()) ?></strong>
                        <span class="price"><?= $product->getFormatedPrice() ?></span>
                    </div>
                </a>
            </div>
        <?php endforeach; ?>
    </div>
</div>

<script type="text/x-magento-init">
    {
    "#<?= $uniqueId ?>": {
        "carousel_test": <?= json_encode($sliderConfig) ?>
    }
}
</script>
