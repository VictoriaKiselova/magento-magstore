<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceContainer name="content">
            <block class="Magento\Framework\View\Element\Template"
                name="tabs-block"
                template="MagStore_Tabs::tabs.phtml"
                before="-">

                <block class="Magento\Framework\View\Element\Template"
                    name="vika.carousel.file.block"
                    as="slider.content"
                    template="MagStore_ProductFeatures::carousel.phtml">
                    <arguments>
                        <argument name="view_model" xsi:type="object">
                            MagStore\ProductFeatures\ViewModel\SliderProducts</argument>
                        <argument name="review_view_model" xsi:type="object">
                            MagStore\ProductFeatures\ViewModel\ReviewSummary</argument>
                    </arguments>
                </block>

                <block class="Magento\Framework\View\Element\Template"
                    name="vika.tabs.contact.wrapper"
                    as="contact.content"
                    template="Magento_Theme::our_contacts.phtml">
                </block>
            </block>
        </referenceContainer>
    </body>
</page>
