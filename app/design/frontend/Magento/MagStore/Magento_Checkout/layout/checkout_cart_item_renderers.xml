<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceBlock name="checkout.cart.item.renderers.default">
            <block class="Magento\Framework\View\Element\Template" name="magstore.reviews.cart"
                template="Magento_Checkout::cart/item/my_reviews.phtml">
                <arguments>
                    <argument name="view_model" xsi:type="object">
                        MagStore\ProductFeatures\ViewModel\ReviewSummary</argument>
                </arguments>
            </block>
        </referenceBlock>
    </body>
</page>
